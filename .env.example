# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/echo
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ENCRYPTION_KEY=your-fernet-encryption-key-change-this

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# LLM Provider Selection
LLM_PROVIDER=groq
# Options: "openai" or "groq"

# OpenAI (for when you switch later)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-openai-org-id

# Groq (FREE tier available!)
GROQ_API_KEY=your-groq-api-key-here
# Get free key at: https://console.groq.com/keys

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# LLM Configuration
# For Groq (recommended models):
CLASSIFICATION_MODEL=llama-3.3-70b-versatile
DRAFTING_MODEL=llama-3.3-70b-versatile
SUMMARIZATION_MODEL=llama-3.3-70b-versatile

# For OpenAI (when you switch):
# CLASSIFICATION_MODEL=gpt-4o-mini
# DRAFTING_MODEL=gpt-4o
# SUMMARIZATION_MODEL=gpt-4o

MAX_TOKENS_PER_USER_DAILY=100000

# Confidence Thresholds
AUTO_SEND_THRESHOLD=0.95
APPROVAL_THRESHOLD=0.70
SUGGESTION_THRESHOLD=0.50

# Email Processing
EMAIL_FETCH_INTERVAL_MINUTES=5
MAX_EMAILS_PER_FETCH=50
STYLE_PROFILE_SAMPLE_SIZE=200
